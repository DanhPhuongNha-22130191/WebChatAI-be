POSTGRES_URL=jdbc:postgresql://your-postgres-host:5432/your_database?sslmode=require
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

MONGODB_URI=mongodb+srv://your_mongo_user:your_mongo_password@your-cluster.mongodb.net/your_database?retryWrites=true&w=majority

REDIS_URL=rediss://default:your_redis_password@your-redis-host:your_redis_port
REDIS_SSL=true

JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRATION_MS=86400000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models
